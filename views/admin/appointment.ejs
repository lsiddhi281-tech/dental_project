<%- include('header.ejs') %>   
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Appointment</h1>
                <p class="text-muted mb-0">A clean starter page for new admin screens.</p>
              </div>
            </div>
            
          </div>
          

          <section class="panel">
            <a href="/admin/appointment_confirm"><button>Appointment Confirm</button></a>
            <a href="/admin/appointment_rejected"><button>Appointment Rejected</button></a>
            <br><br>
            <form action="ap_search" method="get" mt-5>
              <label>From:</label>
              <input type="date" name="from_date">
              <label>To:</label>
              <input type="date" name="to_date">
              <label>Status:</label>
              <select name="status">
                <option value="">select status</option>
                <option value="pending">pending</option>
                <option value="confirm">Confirm</option>
                <option value="reject">Reject</option>
              </select>
              <label>Service:</label>
              <select name="service">
                <option value="">select service</option>
                <% for(var i=0; i<service.length; i++){ %>
                <option value="<%= service[i].sid %>"><%= service[i].title %></option>
                <% } %>
              </select>
              <button>Search:</button>
            </form>
            <table class="table table-border mt-5">
                <tr>
                    <th>Sr.No.</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Service</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
                <% for(var i=0; i<data.length; i++){ %>
                <tr>
                    <td><%= i+1 %></td>
                    <td><%= data[i].name %></td>
                    <td><%= data[i].email %></td>
                    <td><%= data[i].title %></td>
                    <td><%= data[i].adate %></td>
                    <td><%= data[i].status %></td>
                    <td>
                      <a href="/admin/ap_confirm/<%= data[i].aid %>"><button class="btn">Confirm</button></a>
                      <a href="/admin/ap_rejected/<%= data[i].aid %>"><button class="btn">Rejected</button></a>
                    </td>
                </tr>
                <% } %>
            </table>
          </section>
        </div>
      </main>
<%- include('footer.ejs') %>   
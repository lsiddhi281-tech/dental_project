<%- include('header.ejs') %>   
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Blog</h1>
                <p class="text-muted mb-0">A clean starter page for new admin screens.</p>
              </div>
            </div>
            
          </div>
          

          <section class="panel">
            <form action="/admin/blog_save" method="post" enctype="multipart/form-data">
                <label>Photo : </label>
                <input type="file" name="bphoto" class="form-control mb-4">
                <label>Title : </label>
                <input type="text" name="btitle" class="form-control mb-4">
                <label>Date : </label>
                <input type="date" name="bdate" class="form-control mb-4">
                <label>Description :</label>
                <input type="text" name="descrp" class="form-control mb-4">
                <button class="btn btn-primary">Save</button>
            </form>

            <table class="table table-border mt-5">
                <tr>
                    <th>Sr.No.</th>
                    <th>Photo</th>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Description</th>
                    <th>status</th>
                </tr>
                <% for(var i=0; i<data.length; i++){ %>
                <tr>
                    <td><%= i+1 %></td>
                    <td><img src="/<%= data[i].bphoto %>" height="80px"></td>
                    <td><%= data[i].btitle %></td>
                    <td><%= data[i].bdate %></td>
                    <td><%= data[i].descrp %></td>
                    <td>
                        <a href="/admin/blog_edit/<%= data[i].bid %>"><button class="btn">Edit</button></a>
                        <a href="/admin/blog_delete/<%= data[i].bid %>/<%= data[i].bphoto %>"><button class="btn">Delete</button></a>
                    </td>
                </tr>
                <% } %>
            </table>
          </section>
        </div>
      </main>
<%- include('footer.ejs') %>   
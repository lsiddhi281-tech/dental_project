<%- include('header.ejs') %>   
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Our Medical Team</h1>
                <p class="text-muted mb-0">A clean starter page for new admin screens.</p>
              </div>
            </div>
            
          </div>
          

          <section class="panel">
            <form action="/admin/doctors_save" method="post" enctype="multipart/form-data">
                <label>Doctor Photo : </label>
                <input type="file" name="dr_photo" class="form-control mb-4">
                <label>Doctor Name : </label>
                <input type="text" name="dr_name" class="form-control mb-4">
                <label>Speciality : </label>
                <input type="text" name="speciality" class="form-control mb-4">
                <button class="btn btn-primary">Save</button>
            </form>

            <table class="table table-border mt-5">
                <tr>
                    <th>Sr.No.</th>
                    <th>Doctor Photo</th>
                    <th>Doctor Name</th>
                    <th>Speciality</th>
                    <th>status</th>
                </tr>
                <% for(var i=0; i<data.length; i++){ %>
                <tr>
                    <td><%= i+1 %></td>
                    <td><img src="/<%= data[i].dr_photo %>" height="80px"></td>
                    <td><%= data[i].dr_name %></td>
                    <td><%= data[i].speciality %></td>
                    <td>
                        <a href="/admin/doctors_edit/<%= data[i].dr_id %>"><button class="btn">Edit</button></a>
                        <a href="/admin/doctors_delete/<%= data[i].dr_id %>/<%= data[i].dr_photo %>"><button class="btn">Delete</button></a>
                    </td>
                </tr>
                <% } %>
            </table>
          </section>
        </div>
      </main>
<%- include('footer.ejs') %>   
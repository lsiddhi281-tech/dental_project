<%- include('header.ejs') %>   
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Dental Solutions Update</h1>
                <p class="text-muted mb-0">A clean starter page for new admin screens.</p>
              </div>
            </div>
            
          </div>
          

          <section class="panel">
            <form action="/admin/DentalSolutions_update_save/<%= data.ds_id %>" method="post">
                <label>Title : </label>
                <input type="text" value="<%= data.title %>" name="title" class="form-control mb-4">
                <label>Description :</label>
                <input type="text" name="descrp" value="<%= data.descrp %>" class="form-control mb-4">
                <button class="btn btn-primary">Update</button>
            </form>
          </section>
        </div>
      </main>
<%- include('footer.ejs') %>   
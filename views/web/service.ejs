<%- include("header.ejs") %>
        <!--hero section-->
        <section class="hero-section">

            <div class="container text-center">

                <h1 class="hero-title">
                    Professional & Modern Dental Care
                </h1>

                <p class="hero-text">
                    We provide advanced and high-quality dental solutions
                    to keep your smile healthy and bright.
                </p>

                <a href="#" class="btn hero-btn px-5 py-2">
                    Book an Appointment
                </a>

            </div>

        </section>

        <!-- Our Services Section -->
        <section class="container py-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold">Our Services</h2>
                <p class="text-muted">We provide advanced and professional
                    dental care services.</p>
            </div>
            <div class="row g-4">
                <% for(var i=0; i<services.length; i++) { %>
                <div class="col-md-4">
                    <div class="service-card">
                        <i class="bi bi-capsule"></i>
                        <h5><%= services[i].title %></h5>
                        <p><%= services[i].descrp %></p>
                        <a href="#" class="link-primary fw-semibold">Learn More</a>
                    </div>
                </div>
                <% } %>

            </div>
        </section>

        <!-- Appointment Section -->
        <section class="container my-5">

            <div class="row align-items-stretch g-0 no-gap">

                <!-- Text Column (With Background & Circles) -->
                <div class="col-md-7">
                    <div class="appointment-box p-5">

                        <h3 class="fw-bold text-white">
                            Schedule a virtual or presential appointment today
                        </h3>

                        <p class="text-white-50">
                            Virtual & in-clinic consultations available
                        </p>

                        <a class="btn btn-light px-4 fw-semibold">
                            Book an Appointment
                        </a>

                    </div>
                </div>

                <!-- Image Column -->
                <div class="col-md-5">
                    <img src="/web/img/service.jpg"
                        class="equal-img">
                </div>

            </div>

        </section>
<%- include("footer.ejs") %>
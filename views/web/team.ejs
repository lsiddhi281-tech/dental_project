<%- include("header.ejs") %>        
<!-- hero section-->
        <section class="hero-section d-flex align-items-center">
            <div class="container text-center">

                <h1 class="hero-title">
                    Meet Our Professional Dental Team
                </h1>

                <p class="hero-text">
                    Highly qualified and experienced doctors dedicated to
                    providing the best dental care.
                </p>

                <a href="#" class="btn hero-btn px-5 py-2">
                    Book an Appointment
                </a>

            </div>
        </section>
        <!-- team section-->
        <section class="container py-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold">Our Medical Team</h2>
                <p class="text-muted">
                    A team of trusted dentists, orthodontists and dental
                    surgeons.
                </p>
            </div>
            <div class="row g-4">
                <% for(var i=0; i<doctors.length; i++) { %>
                <div class="col-md-4">
                    <div class="team-card">
                        <img src="/<%= doctors[i].dr_photo %>"
                            class="team-img">

                        <h5 class="mt-3 fw-bold"><%= doctors[i].dr_name %></h5>
                        <p class="text-muted"><%= doctors[i].speciality %></p>

                        <a href="#" class="team-link">View Profile</a>
                    </div>
                </div>
                <% } %>
            </div>
        </section>
        <!-- why team section-->
        <section class="container py-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold">Why Our Team?</h2>
            </div>

            <div class="row g-4">
                <% for(var i=0; i<whyTeam.length; i++) { %>
                <div class="col-md-4">
                    <div class="why-team-box">
                        <i class="bi bi-patch-check-fill"></i>
                        <h5 class="fw-bold mt-2"><%= whyTeam[i].title %></h5>
                        <p class="text-muted"><%= whyTeam[i].descrp %></p>
                    </div>
                </div>
                <% } %>
            </div>

        </section>
        <!-- appointment section-->
        <section class="container my-5">

            <div class="row align-items-stretch g-0 no-gap">

                <!-- Text Column (With Background & Circles) -->
                <div class="col-md-7">
                    <div class="appointment-box p-5">

                        <h3 class="fw-bold text-white">
                            Need a Consultation?
                        </h3>

                        <p class="text-white-50">
                            Schedule an appointment with one of our dentists
                            today.
                        </p>

                        <a class="btn btn-light px-4 fw-semibold">
                            Book an Appointment
                        </a>

                    </div>
                </div>

                <!-- Image Column -->
                <div class="col-md-5">
                    <img
                        src="/web/img/teamappo.jpg"
                        class="equal-img">
                </div>

            </div>

        </section>

<%- include("footer.ejs") %>